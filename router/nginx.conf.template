events { worker_connections 1024; }

http {
  server {
    listen      8000;
    server_name localhost;

    # /api/* → backend service (strips /api prefix)
    location /api {
      rewrite /api/(.*) /$1 break;
      proxy_pass http://$BACKEND_SERVICE/;
    }

    # Everything else → frontend
    location / {
      proxy_pass http://$FRONTEND_SERVICE/;
    }
  }
}
