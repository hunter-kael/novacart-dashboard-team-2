# For local development — points to the local backend
REACT_APP_BACKEND_URL=http://localhost:8000

# For SPCS deployment — calls go through NGINX router prefix
# REACT_APP_BACKEND_URL=/api

# Validation mode — must match backend setting
# Dev      = no login, auto-connects as franchise 1
# Snowflake = uses SPCS OAuth (/authorize endpoint)
REACT_APP_CLIENT_VALIDATION=Dev
