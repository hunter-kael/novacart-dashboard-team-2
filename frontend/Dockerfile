FROM node:18-slim

ARG REACT_APP_BACKEND_URL=/api
ARG REACT_APP_CLIENT_VALIDATION=Snowflake
ARG PORT=3000

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

ENV REACT_APP_BACKEND_URL=${REACT_APP_BACKEND_URL}
ENV REACT_APP_CLIENT_VALIDATION=${REACT_APP_CLIENT_VALIDATION}
ENV PORT=${PORT}

EXPOSE ${PORT}
CMD ["npm", "start"]
